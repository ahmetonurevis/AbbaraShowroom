@model IEnumerable<AbbaraShowroom.Models.Product>

@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">🧺 Ürünler</h2>
    <a class="btn btn-primary" asp-action="Create">+ Yeni Ürün</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz hiç ürün eklenmemiş.</div>
}
else
{
    <table class="table table-bordered table-striped shadow-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:5%;">#</th>
                <th>Fotoğraf</th>
                <th>Ürün Adı</th>
                <th>Açıklama</th>
                <th>Kategori</th>
                <th>Renk</th>
                <th>Fiyat</th>
                <th style="width: 180px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="row-@item.Id">
                    <td>@item.Id</td>
                    <td>
                        @if (item.Photos?.Any() == true)
                        {
                            <img src="~/img/uploads/@item.Photos.First().ImagePath" width="60" class="img-thumbnail" />
                        }
                        else
                        {
                            <span class="text-muted">Yok</span>
                        }
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Category?.Name</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.Color))
                        {
                            @item.Color
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (item.Price.HasValue)
                        {
                            @item.Price.Value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">✏ Düzenle</a>
                        <button class="btn btn-sm btn-danger ms-2"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@item.Id"
                                data-name="@item.Name">
                            🗑 Sil
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Modal: Silme Onayı -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Silme Onayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong><span id="deleteItemName"></span></strong> adlı ürünü silmek istiyor musunuz?</p>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="deleteItemId" />
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Evet, Sil</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let selectedId = 0;

        $('#deleteModal').on('show.bs.modal', function (event) {
            const button = $(event.relatedTarget);
            selectedId = button.data('id');
            const name = button.data('name');
            $('#deleteItemName').text(name);
        });

        $('#confirmDeleteBtn').click(function () {
            $.ajax({
                url: '@Url.Action("DeleteConfirmed", "Products")',
                type: 'POST',
                data: { id: selectedId },
                success: function (response) {
                    if (response.success) {
                        $('#deleteModal').modal('hide');
                        $('#row-' + selectedId).fadeOut();
                    } else {
                        alert("❌ Hata: " + response.message);
                    }
                },
                error: function () {
                    alert("Bir hata oluştu.");
                }
            });
        });
    </script>
}
