@model AbbaraShowroom.Models.Slider

@{
    ViewData["Title"] = "Yeni Slider Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">🖼️ Yeni Slider Ekle</h2>

<div class="card shadow-sm p-4 bg-white">

    @* ✔ Toplu validasyon hataları *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>❌ Kayıt başarısız. Lütfen hataları kontrol edin:</strong>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Başlık</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Açıklama</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ButtonText" class="form-label">Buton Metni</label>
            <input asp-for="ButtonText" class="form-control" />
            <span asp-validation-for="ButtonText" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ButtonUrl" class="form-label">Buton Linki</label>
            <input asp-for="ButtonUrl" class="form-control" />
            <span asp-validation-for="ButtonUrl" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Slider Görseli</label>
            <input type="file" name="imageFile" class="form-control" />
            <small class="text-muted">Geniş görsel (örneğin 1200x600) yüklemeniz önerilir.</small>
        </div>

        <button type="submit" class="btn btn-success">✅ Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">↩ Geri Dön</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
