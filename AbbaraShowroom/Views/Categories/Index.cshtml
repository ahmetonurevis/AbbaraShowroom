@model IEnumerable<AbbaraShowroom.Models.Category>

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">📁 Kategori Listesi</h2>

<a asp-action="Create" class="btn btn-success mb-3">➕ Yeni Kategori Ekle</a>

<table class="table table-bordered shadow-sm bg-white">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Kategori Adı</th>
            <th style="width: 160px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr id="row-@item.Id">
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">✏ Düzenle</a>
                    <button type="button" class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-id="@item.Id"
                            data-name="@item.Name">
                        🗑 Sil
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal: Silme Onayı -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Silme Onayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong><span id="deleteItemName"></span></strong> adlı kategoriyi silmek istiyor musunuz?</p>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="deleteItemId" />
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Evet, Sil</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        let selectedId = 0;

        $('#deleteModal').on('show.bs.modal', function (event) {
            const button = $(event.relatedTarget);
            selectedId = button.data('id');
            const name = button.data('name');

            $('#deleteItemId').val(selectedId);
            $('#deleteItemName').text(name);
        });

        $('#confirmDeleteBtn').click(function () {
            $.ajax({
                url: '@Url.Action("DeleteConfirmed", "Categories")',
                type: 'POST',
                data: { id: selectedId },
                success: function (response) {
                    if (response.success) {
                        $('#deleteModal').modal('hide');
                        $('#row-' + selectedId).fadeOut();
                    } else {
                        alert("❌ Hata: " + response.message);
                    }
                },
                error: function () {
                    alert("Sunucu hatası oluştu.");
                }
            });
        });
    </script>
}
