@model AbbaraShowroom.Models.Category

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">📁 Yeni Kategori Ekle</h2>

<div class="card shadow-sm p-4 bg-white">

    @* VALIDASYON HATALARI *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>❌ Kayıt başarısız. Lütfen hataları kontrol edin:</strong>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post" novalidate>
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Kategori Adı</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">
                ✅ Kaydet
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                ↩ Geri Dön
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <!-- jQuery ve validasyon kütüphaneleri -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
}
