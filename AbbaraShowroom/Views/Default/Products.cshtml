@model List<AbbaraShowroom.Models.Product>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tüm Ürünler";

    var categories = ViewBag.Categories as List<string>;
    var selected = (ViewBag.SelectedCategory as string)?.ToLower();
}

<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4">Tüm Ürünler</h2>

        <!-- ✅ Kategori Butonları -->
        <div class="d-flex justify-content-center flex-wrap gap-2 mb-4">
            <a asp-action="Products" asp-route-category=""
               class="btn btn-sm @(string.IsNullOrEmpty(selected) ? "btn-primary" : "btn-outline-primary")">Tümü</a>

            @foreach (var cat in categories)
            {
                var isActive = selected == cat.ToLower();
                <a asp-action="Products"
                   asp-route-category="@cat"
                   class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-primary")">
                    @cat
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">Seçilen kategoriye ait ürün bulunamadı.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    <div class="col-md-3">
                        <div class="card h-100 shadow-sm border-0">
                            @if (product.Photos?.Any() == true)
                            {
                                <div class="d-flex align-items-center justify-content-center bg-white" style="height: 200px; overflow: hidden;">
                                    <img src="~/img/uploads/@product.Photos.First().ImagePath"
                                         class="img-fluid"
                                         style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                                </div>
                            }
                            else
                            {
                                <div class="bg-secondary text-white text-center py-5">Fotoğraf Yok</div>
                            }

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@product.Name</h5>
                                <p class="text-muted mb-1">@product.Category?.Name</p>

                                @if (!string.IsNullOrWhiteSpace(product.Color))
                                {
                                    <p class="mb-1"><strong>Renk:</strong> @product.Color</p>
                                }

                                @if (product.Price.HasValue)
                                {
                                    <p class="text-success fw-semibold mb-1">
                                        @product.Price.Value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                                    </p>
                                }

                                <p class="card-text text-truncate small">@product.Description</p>

                                <a asp-action="ProductDetail" asp-route-id="@product.Id" class="btn btn-outline-primary mt-auto">İncele</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
