@model AbbaraShowroom.Models.HomePageViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- SLIDER BÖLÜMÜ -->
@await Html.PartialAsync("_HomeSlider", Model.Sliders)

<!-- ÖNE ÇIKAN ÜRÜNLER -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-4">⭐ Öne Çıkan Ürünler</h2>

        @if (!Model.Products.Any())
        {
            <div class="alert alert-info text-center">Öne çıkarılmış ürün bulunmamaktadır.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col-md-3">
                        <div class="card h-100 shadow-sm border-0">
                            @if (product.Photos?.Any() == true)
                            {
                                <img src="~/img/uploads/@product.Photos.First().ImagePath"
                                     class="card-img-top"
                                     alt="@product.Name"
                                     style="height: 200px; object-fit: contain; background-color: #f8f9fa;" />
                            }
                            else
                            {
                                <div class="bg-secondary text-white text-center py-5">Fotoğraf Yok</div>
                            }

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@product.Name</h5>
                                <p class="text-muted mb-1">@product.Category?.Name</p>

                                @if (!string.IsNullOrWhiteSpace(product.Color))
                                {
                                    <p class="mb-1"><strong>Renk:</strong> @product.Color</p>
                                }

                                @if (product.Price.HasValue)
                                {
                                    <p class="text-success fw-semibold mb-1">
                                        @product.Price.Value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                                    </p>
                                }

                                <a asp-action="ProductDetail" asp-route-id="@product.Id" class="btn btn-outline-primary mt-auto">İncele</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-4">
                <a asp-action="Products" class="btn btn-primary px-4">Tüm Ürünleri Gör</a>
            </div>
        }
    </div>
</section>
