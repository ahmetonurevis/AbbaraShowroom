@model List<AbbaraShowroom.Models.Slider>

@if (Model != null && Model.Any())
{
    <div id="homepageSlider" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-inner rounded shadow">

            @for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <div class="position-relative d-flex align-items-center justify-content-center" style="height: 450px; background-color: #f5f5f5;">
                        <img src="~/img/uploads/@item.ImagePath"
                             alt="@item.Title"
                             class="position-absolute top-0 start-0 w-100 h-100"
                             style="object-fit: contain;" />

                        <div class="position-relative text-center text-white bg-dark bg-opacity-50 p-4 rounded">
                            <h2 class="display-5 fw-bold">@item.Title</h2>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="lead">@item.Description</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.ButtonText) && !string.IsNullOrWhiteSpace(item.ButtonUrl))
                            {
                                <a href="@item.ButtonUrl" class="btn btn-light mt-2">@item.ButtonText</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#homepageSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homepageSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
}
