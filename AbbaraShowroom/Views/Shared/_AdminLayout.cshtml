<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            background-color: #f1f4f9;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            background: linear-gradient(180deg, #6f42c1, #563d7c);
            color: #fff;
            padding-top: 20px;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
        }

            .sidebar h4 {
                text-align: center;
                font-weight: bold;
                margin-bottom: 30px;
            }

            .sidebar .nav-link {
                color: #e0e0e0;
                padding: 12px 20px;
                font-size: 15px;
                display: flex;
                align-items: center;
                gap: 10px;
                border-radius: 8px;
                margin: 4px 10px;
                transition: all 0.2s ease-in-out;
            }

                .sidebar .nav-link:hover,
                .sidebar .nav-link.active {
                    background-color: rgba(255, 255, 255, 0.15);
                    color: #fff;
                }

        .main-wrapper {
            margin-left: 250px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 60px;
            background-color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
        }

            .topbar .user-info {
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 10px;
            }

        .admin-header {
            padding: 25px 30px 0;
            font-size: 24px;
            font-weight: 600;
            color: #333;
        }

        .admin-body {
            padding: 20px 30px;
            flex: 1;
        }

        @@media (max-width: 768px) {
            .sidebar

        {
            position: relative;
            width: 100%;
            height: auto;
            padding: 10px;
        }

        .main-wrapper {
            margin-left: 0;
        }

        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h4>
            <a asp-controller="Dashboard" asp-action="Index" class="text-white text-decoration-none d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-box"></i> <span>Abbara</span>
            </a>
        </h4>
        <ul class="nav flex-column">
            <li><a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
            <li><a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i> Kategoriler</a></li>
            <li><a class="nav-link" asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam"></i> Ürünler</a></li>
            <li> <a class="nav-link" asp-controller="Sliders" asp-action="Index"><i class="bi bi-images"></i> Sliderlar</a></li>
            <li><a class="nav-link" asp-controller="Messages" asp-action="Index"><i class="bi bi-envelope"></i> Mesajlar</a></li>
            <li><a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Çıkış</a></li>
        </ul>
    </div>

    <!-- Main Area -->
    <div class="main-wrapper">
        <div class="topbar">
            <div class="page-title">@ViewData["Title"]</div>
            <div class="user-info">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle fs-5 text-secondary"></i>
                        <span class="fw-semibold text-dark">Admin</span>
                    </div>
                    <a asp-controller="Default" asp-action="Index" target="_blank"
                       class="btn btn-sm btn-light border rounded-pill px-3 d-flex align-items-center gap-2 shadow-sm">
                        <i class="bi bi-box-arrow-up-right"></i>
                        Siteye Git
                    </a>
                </div>
            </div>
        </div>


        <div class="admin-header">@ViewData["Title"]</div>
        <div class="admin-body">
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>

</html>